generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Card {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  cardType         String        @map("card_type")
  power            Int?
  activeCost       String        @default("") @map("active_cost")
  activeEffect     String        @default("") @map("active_effect")
  mainCost         String?       @map("main_cost")
  mainEffect       String?       @map("main_effect")
  subCost          String?       @map("sub_cost")
  subEffect        String?       @map("sub_effect")
  collectionNumber String        @unique @map("collection_number")
  releases         CardRelease[]
  deckItems        DeckCard[]

  @@index([name], map: "cards_name_idx")
  @@index([cardType], map: "cards_card_type_idx")
  @@map("cards")
}

model Deck {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  authorId    String     @map("author_id") @db.Uuid
  description String?
  items       DeckCard[]
  author      User       @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId], map: "decks_author_id_idx")
  @@map("decks")
}

model DeckCard {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deckId       String @map("deck_id") @db.Uuid
  cardId       String @map("card_id") @db.Uuid
  slotType     String @map("slot_type")
  quantity     Int    @default(1)
  displayOrder Int    @default(0) @map("display_order")

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Restrict)

  @@unique([deckId, cardId], map: "deck_cards_deck_card_unique")
  @@index([deckId], map: "deck_cards_deck_id_idx")
  @@index([cardId], map: "deck_cards_card_id_idx")
  @@index([slotType], map: "deck_cards_slot_type_idx")
  @@map("deck_cards")
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  loginId             String               @unique @map("login_id")
  email               String               @unique
  displayName         String?              @map("display_name")
  passwordHash        String?              @map("password_hash")
  role                String               @default("USER")
  sessions            AuthSession[]
  oauthAccounts       OAuthAccount[]
  passwordResetTokens PasswordResetToken[]
  decks               Deck[]

  @@index([role], map: "users_role_idx")
  @@map("users")
}

model AuthSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model OAuthAccount {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  provider          String
  providerAccountId String  @map("provider_account_id")
  email             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "oauth_accounts_provider_account_unique")
  @@index([userId], map: "oauth_accounts_user_id_idx")
  @@map("oauth_accounts")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model Pack {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  releaseDate DateTime      @map("release_date") @db.Date
  codePrefix  String        @unique @map("code_prefix")
  releases    CardRelease[]

  @@map("packs")
}

model CardRelease {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardName         String   @map("card_name")
  cardId           String   @map("card_id") @db.Uuid
  rarity           String
  packId           String   @map("pack_id") @db.Uuid
  collectionNumber String   @map("collection_number")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  pack Pack @relation(fields: [packId], references: [id], onDelete: Restrict)

  @@unique([cardId, packId, rarity], map: "card_releases_card_pack_rarity_unique")
  @@unique([collectionNumber, rarity], map: "card_releases_collection_rarity_unique")
  @@index([cardId], map: "card_releases_card_id_idx")
  @@index([packId], map: "card_releases_pack_id_idx")
  @@index([rarity], map: "card_releases_rarity_idx")
  @@map("card_releases")
}
